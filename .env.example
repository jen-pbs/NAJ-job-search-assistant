# Notion API (optional - for saving contacts/jobs/events to Notion)
NOTION_API_KEY=ntn_your_notion_integration_token
NOTION_DATABASE_ID=your_notion_database_id

# AI provider (optional - enables query interpretation and relevance scoring)
# You can set a default Groq key here, or configure any provider (OpenAI, OpenRouter, etc.)
# directly in the app UI via the "Update model" button.
GROQ_API_KEY=your_groq_api_key
